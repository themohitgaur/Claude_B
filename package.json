{
  "name": "claude-bootstrap-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "AI Workspace Generator for Claude Code - monorepo root",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "cli": "pnpm --filter @claude-bootstrap/cli start"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.7.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "license": "MIT"
}
