{
  "name": "@themohitgaur1/claude-bootstrap",
  "version": "1.0.1",
  "description": "AI Workspace Generator for Claude Code — turn any repo into a configured Claude Code workspace in under a minute.",
  "type": "module",
  "bin": {
    "claude-bootstrap": "./bin/claude-bootstrap.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "bin", "README.md"],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agents",
    "mcp",
    "subagents",
    "hooks",
    "skills",
    "agents.md",
    "scaffold",
    "cli",
    "bootstrap"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "start": "node ./bin/claude-bootstrap.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@themohitgaur1/scanner": "workspace:*",
    "@themohitgaur1/generators": "workspace:*",
    "@themohitgaur1/templates": "workspace:*",
    "commander": "^12.1.0",
    "inquirer": "^12.11.1",
    "chalk": "^5.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.7.0"
  },
  "engines": { "node": ">=18.0.0" },
  "publishConfig": { "access": "public" },
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/themohitgaur1/claude-bootstrap" },
  "homepage": "https://github.com/themohitgaur1/claude-bootstrap#readme"
}
